#!/usr/bin/env bash
[ -z "$DEBUG" ] || set -x
set -eo pipefail

PROVISIONER=$(y-cluster-local-detect)

case "$PROVISIONER" in
  k3d)
    docker exec -i k3d-ystack-server-0 ctr "$@"
    ;;
  multipass)
    multipass exec ystack-master -- sudo k3s ctr "$@"
    ;;
  lima)
    limactl shell ystack sudo k3s ctr "$@"
    ;;
  qemu)
    ssh -p 2222 -i "$HOME/.cache/ystack-qemu/ystack-qemu-ssh" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null ystack@localhost sudo k3s ctr "$@"
    ;;
esac
