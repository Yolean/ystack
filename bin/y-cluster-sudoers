#!/usr/bin/env bash
[ -z "$DEBUG" ] || set -x
set -eo pipefail

YSTACK_HOME="$(cd "$(dirname "$0")/.." && pwd)"
YBIN="$YSTACK_HOME/bin"

SUDOERS_FILE="/etc/sudoers.d/ystack-cluster"

usage() {
  cat >&2 <<EOF
Usage: y-cluster-sudoers [--write]

Maintains passwordless sudo rules for automatic development cluster setup.

Without --write: prints the sudoers rules that would be written.
With    --write: writes the rules to $SUDOERS_FILE (requires sudo).
EOF
  exit 0
}

[ "$1" = "-h" ] || [ "$1" = "--help" ] && usage

WRITE=false
[ "$1" = "--write" ] && WRITE=true

CURRENT_USER="${SUDO_USER:-$USER}"

rules() {
  cat <<EOF
# ystack development cluster automation
# Generated by y-cluster-sudoers for user $CURRENT_USER
# YSTACK_HOME=$YSTACK_HOME

# y-localhost: loopback alias management
$CURRENT_USER ALL=(root) NOPASSWD: $YBIN/y-localhost *

# y-k8s-ingress-hosts: /etc/hosts management
$CURRENT_USER ALL=(root) NOPASSWD: $YBIN/y-k8s-ingress-hosts-v*-bin *
EOF
}

if [ "$WRITE" = "true" ]; then
  if [ $(id -u) -ne 0 ]; then
    echo "Writing sudoers rules requires root. Re-running with sudo ..."
    exec sudo "$0" --write
  fi
  TMPFILE=$(mktemp)
  rules > "$TMPFILE"
  # Validate before installing
  if visudo -cf "$TMPFILE"; then
    cp "$TMPFILE" "$SUDOERS_FILE"
    chmod 0440 "$SUDOERS_FILE"
    rm "$TMPFILE"
    echo "Wrote $SUDOERS_FILE"
  else
    rm "$TMPFILE"
    echo "ERROR: Generated sudoers rules failed validation" >&2
    exit 1
  fi
else
  echo "# Sudoers rules that would be written to $SUDOERS_FILE"
  echo "# Run 'y-cluster-sudoers --write' to install them."
  echo ""
  rules
fi
