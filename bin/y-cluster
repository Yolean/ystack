#!/bin/bash
[ -z "$DEBUG" ] || set -x
set -e
YBIN="$(dirname "$0")"

# Dev mode: use locally built binary at bin/y-cluster-dev (often a
# symlink to bin/y-cluster-<sha>). bin/kubectl-yconverge is a tracked
# symlink to bin/y-cluster so `kubectl yconverge ...` resolves through
# PATH plugin discovery. Use exec -a so the binary sees the invocation
# name and can detect kubectl-plugin mode.
DEV_BIN="$YBIN/y-cluster-dev"
if [ -x "$DEV_BIN" ]; then
  exec -a "$(basename "$0")" "$DEV_BIN" "$@"
fi

# TODO: release mode via y-bin-download
# version=$(y-bin-download $YBIN/y-bin.runner.yaml y-cluster)
# exec "y-cluster-v${version}-bin" "$@"

echo "No y-cluster binary found. Build one:" >&2
echo "  (cd ~/Yolean/y-cluster && go build -o $DEV_BIN ./cmd/y-cluster/)" >&2
exit 1
